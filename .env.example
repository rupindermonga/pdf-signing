# DocSeal Configuration
PORT=3000
BASE_URL=http://localhost:3000

# SMTP Email (optional - signing links shown in dashboard if not configured)
# Works with ANY email provider that supports SMTP:
#
#   Gmail:       SMTP_HOST=smtp.gmail.com       SMTP_PORT=587
#                (use App Password: https://myaccount.google.com/apppasswords)
#   Outlook:     SMTP_HOST=smtp.office365.com   SMTP_PORT=587
#   Yahoo:       SMTP_HOST=smtp.mail.yahoo.com  SMTP_PORT=587
#   Zoho:        SMTP_HOST=smtp.zoho.com        SMTP_PORT=587
#   SendGrid:    SMTP_HOST=smtp.sendgrid.net    SMTP_PORT=587
#   AWS SES:     SMTP_HOST=email-smtp.us-east-1.amazonaws.com SMTP_PORT=587
#   Custom:      Any SMTP server works
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_NAME=DocSeal
FROM_EMAIL=

# Session secret (change this in production)
SESSION_SECRET=docseal-secret-change-me

# P12 certificate passphrase (default: docseal)
P12_PASSPHRASE=docseal
