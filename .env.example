# DocSeal Configuration
PORT=3000
BASE_URL=http://localhost:3000

# SMTP Email (optional - signing links shown in dashboard if not configured)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use an App Password, not your Gmail password: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_NAME=DocSeal
FROM_EMAIL=

# Session secret (change this in production)
SESSION_SECRET=docseal-secret-change-me
